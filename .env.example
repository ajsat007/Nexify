# ── Nexify Environment Configuration ──
# Copy this to .env.local and fill in values

# Site
NEXT_PUBLIC_SITE_URL=https://nexify.tech
NEXT_PUBLIC_SITE_NAME=Nexify Technologies

# AI Provider (choose one)
# Supported: openai, anthropic, gemini, deepseek, mistral, ollama
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# API Keys (only needed for providers you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional: Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Optional: Database (PostgreSQL via Supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Analytics
NEXT_PUBLIC_GA_ID=
